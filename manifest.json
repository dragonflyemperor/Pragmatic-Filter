{
  "manifest_version": 3,
  "name": "Pragmatic Filter",
  "version": "1.1",
  "description": "Hides social media posts containing specific keywords.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configure Keywords"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.twitter.com/*",
        "*://x.com/*",
        "*://*.instagram.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
